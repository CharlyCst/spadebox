# Mock server — no API key required, start with: `just mock-server`
# LLM_BASE_URL=http://localhost:8324
# LLM_MODEL=mock
# LLM_API_KEY=

# Mistral API (https://console.mistral.ai)
# LLM_BASE_URL=https://api.mistral.ai
# LLM_MODEL=mistral-small-latest
# LLM_API_KEY=your-mistral-api-key

# Codestral API — code-focused Mistral model (https://console.mistral.ai)
# LLM_BASE_URL=https://codestral.mistral.ai
# LLM_MODEL=codestral-latest
# LLM_API_KEY=your-codestral-api-key
